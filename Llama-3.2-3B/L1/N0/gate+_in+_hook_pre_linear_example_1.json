{
    "tokens": [
        "<|begin_of_text|>",
        "All",
        " these",
        " low",
        "-level",
        " algorithms",
        " are",
        " used",
        " in",
        " the",
        " implementation",
        " of",
        " higher",
        "-level",
        " functionality",
        " in",
        " our",
        " research",
        " projects",
        ".\n",
        "Matrix",
        " Programming",
        " is",
        " at",
        " the",
        " core",
        " of",
        " mathematical",
        " models",
        " and",
        " it",
        " is",
        " vital",
        " do",
        " it",
        " carefully",
        " and",
        " precisely",
        ".",
        " It",
        " is",
        " easy",
        " to",
        " create",
        " software",
        " that",
        " implements",
        " matrix",
        " operations",
        " exactly",
        " as",
        " they",
        " are",
        " spelled",
        " out",
        " in",
        " a",
        " matrix",
        " equation",
        ".",
        " But",
        " that",
        " is",
        " seldom",
        " the",
        " best",
        " way",
        " to",
        " do",
        " it",
        ".",
        " For",
        " example",
        ",",
        " matrices",
        " may",
        " be",
        " \"",
        "un",
        "stable",
        "\"",
        " due",
        " to",
        " being",
        " close",
        " to",
        " \"",
        "singular",
        "\"",
        " or",
        " for",
        " other",
        " reasons",
        " while",
        " still",
        " being",
        " valid",
        " algebra",
        "ically",
        ".",
        " It",
        " would",
        " be",
        " dangerous",
        " to",
        " program",
        " without",
        " taking",
        " that",
        " into",
        " account",
        ".",
        " Singular",
        " and",
        " unstable",
        " matrices",
        " are",
        " common",
        " in",
        " data",
        " analysis",
        " due",
        " to",
        " measured",
        " data",
        " being",
        " correlated",
        " with",
        " each",
        " other",
        ".",
        " So",
        " matrix",
        " operations",
        " are",
        " seldom",
        " programmed",
        " as",
        " they",
        " are",
        " written",
        ".\n",
        "That",
        "'s",
        " why",
        " numerical",
        " programmers",
        " use",
        " LU",
        " and",
        " Ch",
