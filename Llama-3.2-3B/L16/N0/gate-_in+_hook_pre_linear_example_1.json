        " have",
        " conducted",
        " research",
        " among",
        " our",
        " audience",
        ",",
        " and",
        " today",
        " we",
        " will",
        " share",
        " the",
        " results",
        " of",
        " our",
        " survey",
        " with",
        " you",
        ".\n",
