    "tokens": [
        "<|begin_of_text|>",
        "We",
        " really",
        " want",
        " to",
        " understand",
        " how",
        " much",
        " our",
        " society",
        " is",
        " protected",
        " in",
        " the",
        " fight",
        " against",
        " coronavirus",
        ".",
