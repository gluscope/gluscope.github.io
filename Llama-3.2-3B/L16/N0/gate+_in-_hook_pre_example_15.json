    "tokens": [
        "<|begin_of_text|>",
        "Policy",
        " prepared",
        " by",
        ":",
        " Claire",
        " Crom",
        "bie",
        ".\n",
        "Approved",
        " by",
        " board",
        "/",
        "management",
        " on",
        ":",
        " ",
        "20",
        "th",
        " May",
        " ",
        "201",
        "8",
        ".\n",
        "The",
        " policy",
        " became",
        " operational",
        " on",
        ":",
        " ",
        "25",
        "th",
        " May",
        " ",
        "201",
        "8",
        ".\n",
        "Rare",
        "ly",
        " Impossible",
        " needs",
        " to",
        " gather",
        " and",
        " use",
        " certain",
        " information",
        " about",
        " individuals",
        ".\n",
        "The",
        " Data",
        " Protection",
        " Act",
        " ",
        "199",
        "8",
        " describes",
        " how",
        " organisations",
        " \u2014",
        " including",
        " Rare",
        "ly",
        " Impossible",
        "\u2014",
        " must",
        " collect",
        ",",
        " handle",
        " and",
        " store",
        " personal",
        " information",
        ".\n",
        "Everyone",
        " who",
        " works",
        " for",
        " or",
        " with",
        " Rare",
        "ly",
        " Impossible",
        " has",
        " some",
        " responsibility",
        " for",
        " ensuring",
        " data",
        " is",
        " collected",
        ",",
        " stored",
        " and",
        " handled",
        " appropriately",
        ".\n",
        "The",
        " board",
        " of",
        " directors",
        " is",
        " ultimately",
        " responsible",
        " for",
        " ensuring",
        " that",
        " Rare",
        "ly",
        " Impossible",
        " meets",
        " its",
        " legal",
        " obligations",
        ".\n",
        "De",
        "aling",
        " with",
        " requests",
        " from",
        " individuals",
        " to",
        " see",
        " the",
        " data",
        " Rare",
        "ly",
        " Impossible",
        " holds",
        " about",
        " them",
        " (",
        "also",
        " called",
        " \u2018",
        "subject",
        " access",
        " requests",
        "\u2019",
        ").\n",
        "Rare",
        "ly",
        " Impossible",
        " will",
        " provide",
        " training",
        " to",
        " all",
        " employees",
        " to",
        " help",
        " them",
        " understand",
        " their",
        " responsibilities",
        " when",
        " handling",
        " data",
        ".\n",
        "These",
        " rules",
        " describe",
        " how",
        " and",
        " where",
        " data",
        " should",
        " be",
        " safely",
        " stored",
        ".",
        " Questions",
        " about",
        " storing",
        " data",
        " safely",
        " can",
        " be",
        " directed",
        " to",
        " the",
        " Managing",
        " Director",
        ".\n",
        "Data",
        " should",
        " only",
        " be",
        " stored",
        " on",
        " designated",
        " drives",
        " and",
        " servers",
        " and",
        " should",
        " only",
        " be",
        " uploaded",
        " to",
        " approved",
        " cloud",
        " computing",
        " services",
        ".\n",
        "Data",
        " must",
        " be",
        " encrypted",
        " before",
        " being",
        " transferred",
        " electronically",
        ".",
        " The",
        " Managing",
        " Director",
        " can",
        " explain",
        " how",
        " to",
        " send",
        " data",
        " to",
        " authorised",
        " external",
        " contacts"
