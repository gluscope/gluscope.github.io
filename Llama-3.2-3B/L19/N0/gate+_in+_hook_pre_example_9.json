    "tokens": [
        "<|begin_of_text|>",
        "This",
        " dissertation",
        " develops",
        " new",
        " algorithms",
        " with",
        " different",
        " techniques",
        " in",
        " utilizing",
        " spatial",
        " and",
        " spectral",
        " information",
        " for",
        " hypers",
        "pectral",
        " image",
        " classification",
        ".",
        " It",
        " is",
        " necessary",
        " to",
        " perform",
        " spatial",
        " and",
        " spectral",
        " analysis",
        " and",
        " conduct",
        " dimension",
        "ality",
        " reduction",
        " (",
        "DR",
        ")",
        " for",
        " effective",
        " feature",
        " extraction",
        ",",
        " because",
        " hypers",
        "pectral",
        " imagery",
        " consists",
        " of",
        " a",
        " large",
        " number",
        " of",
        " spatial",
        " pixels",
        " along",
        " with",
        " hundreds",
        " of",
        " spectral",
        " dimensions",
        ".\n",
        "In",
        " the",
        " first",
        " proposed",
        " method",
        ",",
        " it",
        " employs",
        " spatial",
        "-aware",
        " collaboration",
        "-",
        "competition",
        " preserving",
        " graph",
        " embedding",
        " by",
        " imposing",
        " a",
        " spatial",
        " regularization",
        " term"
    ],
