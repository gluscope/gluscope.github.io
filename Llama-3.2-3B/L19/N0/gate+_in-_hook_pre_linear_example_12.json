    "tokens": [
        "<|begin_of_text|>",
        "Researchers",
        " developing",
        " prediction",
        " models",
        " are",
        " faced",
        " with",
        " numerous",
        " design",
        " choices",
        " that",
        " may",
        " impact",
        " model",
        " performance",
        ".",
        " One",
        " key",
        " decision",
        " is",
        " how",
        " to",
        " include",
        " patients",
        " who",
        " are",
        " lost",
        " to",
        " follow",
        "-up",
        ".",
        " In",
        " this",
        " paper",
        " we",
        " perform",
        " a",
        " large",
        "-scale",
        " empirical",
        " evaluation",
        " investigating",
        " the",
        " impact",
        " of",
        " this",
        " decision",
        ".",
