        " addition",
        ",",
        " we",
        " aim",
        " to",
        " provide",
        " guidelines",
        " for",
        " how",
        " to",
        " deal",
        " with",
        " loss",
        " to",
        " follow",
        "-up",
        ".\n",
        "We",
        " generate",
        " a",
        " partially",
        " synthetic",
        " dataset",
        " with",
        " complete",
        " follow",
        "-up",
        " and",
        " simulate",
        " loss",
        " to",
        " follow",
        "-up",
        " based",
        " either",
        " on",
        " random",
        " selection",
        " or",
        " on",
        " selection",
        " based",
        " on",
        " com",
        "orb",
        "idity",
        ".",
        " In",
        " addition",
        " to",
        " our",
        " synthetic",
        " data",
        " study",
        " we",
        " investigate",
        " ",
        "21",
        " real",
        "-world",
        " data",
        " prediction",
        " problems",
        ".",
        " We",
        " compare",
        " four",
        " simple",
        " strategies"
