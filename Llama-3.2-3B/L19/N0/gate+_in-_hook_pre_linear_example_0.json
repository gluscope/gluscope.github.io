        " these",
        " models",
        " show",
        " superior",
        " performance",
        " than",
        " a",
        " single",
        " model",
        ",",
        " there",
        " is",
        " the",
        " scope",
        " of",
        " further",
        " improvement",
        " if",
        " the",
        " underlying",
        " feature",
        " laid",
        " in",
        " the",
        " original",
        " data",
        " is",
        " augmented",
        " before",
        " applying",
        " models",
        ".",
        " In",
        " this",
        " work",
        ",",
        " empirical",
        " wave",
        "let",
        " transform",
        " (",
        "E",
        "WT",
        ")",
        " is",
        " implemented",
        " to",
        " decom",
        "pose",
        " the",
        " original",
        " series",
