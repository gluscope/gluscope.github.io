    "tokens": [
        "<|begin_of_text|>",
        "Enh",
        "ancing",
        " Neural",
        " Network",
        " Based",
        " Hybrid",
        " Learning",
        " with",
        " Emp",
        "irical",
        " Wave",
        "let",
        " Transform",
        " for",
        " Time",
        " Series",
        " Forecast",
        "ing",
        "\n\n",
        "Over",
        " the",
        " past",
        " decades",
        ",",
        " the",
        " hybrid",
        " models",
        " which",
        " integrate",
        " param",
        "etric",
        " and",
        " non",
        "-param",
        "etric",
        " learning",
        " models",
        " have",
        " proven",
        " to",
        " be",
        " a",
        " viable",
        " method",
        " in",
        " time",
        " series",
        " forecasting",
        ".",
        " Several",
        " structures",
        " were",
        " proposed",
        " as",
        " a",
        " combination",
        " of",
        " param",
        "etric",
        " models",
        " such",
        " as",
        " aut",
        "ore",
        "gressive",
        " moving",
        " average",
        " (",
        "AR",
        "IMA",
        ")",
        " and",
        " non",
        "-param",
        "etric",
        " models",
        " such",
        " as",
        " artificial",
        " neural",
        " network",
        " (",
        "ANN",
        ").",
