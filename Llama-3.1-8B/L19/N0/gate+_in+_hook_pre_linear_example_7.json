        " get",
        " from",
        " conversations",
        " and",
        " use",
        " your",
        " map",
        " to",
        " find",
        " out",
        " where",
        " you",
        " are",
        " and",
        " where",
        " your",
        " daughter",
        " might",
        " be",
        ".",
        " Listen",
        " carefully",
        " for",
        " warnings",
        " about",
        " enemies",
        " or",
        " where",
        " to",
        " find",
        " information",
        " or",
        " weapons",
        ".\n",
        "While",
        " this",
        " is",
        " not",
        " a",
        " combat",
        " game",
        ",",
        " there",
        " will",
        " be",
        " times",
        " where",
        " you",
        " will",
