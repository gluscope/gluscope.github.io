    "tokens": [
        "<|begin_of_text|>",
        "The",
        " main",
        " mission",
        " in",
        " the",
        " game",
        " is",
        " to",
        " rescue",
        " your",
        " daughter",
        ",",
        " who",
        " has",
        " been",
        " captured",
        " by",
        " slave",
        " traders",
        ".",
        " There",
        " are",
        " no",
        " pointless",
        " side",
        " quests",
        ",",
        " you",
        " don",
        "'t",
        " have",
        " time",
        " to",
        " gamble",
        " or",
        " go",
        " off",
        " on",
        " adventures",
        ".",
        " So",
        " any",
        " side",
        " quests",
        " are",
        " in",
        " pursuit",
        " of",
        " finding",
        " your",
        " daughter",
        ".\n",
        "A",
        " major",
        " part",
        " of",
        " the",
        " game",
        " is",
        " exploration",
        ",",
        " so",
        " you",
        " will",
        " have",
        " to",
        " follow",
        " clues",
