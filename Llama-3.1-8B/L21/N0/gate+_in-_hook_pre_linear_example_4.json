    "tokens": [
        "<|begin_of_text|>",
        "Bre",
        "ast",
        " cancer",
        " has",
        " become",
        " a",
        " common",
        " mortality",
        " factor",
        " in",
        " the",
        " world",
        ".",
        " Lesser",
        " availability",
        " of",
        " diagnostic",
        " facilities",
        " along",
        " with",
        " large",
        " time",
        " requirements",
        " in",
        " manual",
        " diagnosis",
        " emphasize",
        " on",
        " automatic",
        " diagnosis",
        " for",
        " early",
        " diagnosis",
        " of",
        " the",
        " disease",
        ".",
        " In",
        " this",
        " paper",
        " a",
        " computer",
        "ized",
        " breast",
        " cancer",
        " diagnosis",
        " prototype",
        " has",
        " been",
        " developed",
        " to",
        " reduce",
        " the",
        " time",
        " taken",
        " and",
        " indirectly",
        " reducing",
        " the",
        " probability",
        " of",
        " death",
        ".",
