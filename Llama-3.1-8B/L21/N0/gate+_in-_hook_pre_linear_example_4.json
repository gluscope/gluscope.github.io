        " this",
        " research",
        " two",
        " stage",
        " of",
        " LV",
        "Q",
        " network",
        " is",
        " used",
        " on",
        " W",
        "DBC",
        " datasets",
        ".",
        " The",
        " first",
        " level",
        " of",
        " LV",
        "Q",
        " reduces",
        " the",
        " feature",
        " space",
